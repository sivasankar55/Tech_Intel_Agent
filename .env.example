# Daily AI & Tech Intelligence Agent Configuration

# --- Google Gemini API ---
# Get API Key: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram Bot Delivery ---
# Create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Email SMTP Delivery ---
# Gmail: use App Password (16 chars, no spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password_here
EMAIL_TO=recipient_email@gmail.com

# --- Web Scraper (Firecrawl) ---
# Sign up at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# --- Twitter/X Scraping ---
# ScrapingDog: https://www.scrapingdog.com/
# Twitter Bearer Token: https://developer.x.com/
SCRAPINGDOG_API_KEY=your_scrapingdog_api_key_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# --- GitHub API ---
# https://github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=your_github_token_here

# --- Product Hunt API v2 ---
# https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_DEVELOPER_TOKEN=your_product_hunt_developer_token_here
